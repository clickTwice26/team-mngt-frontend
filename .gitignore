# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------------------------------------------------------------------------
# Secrets & environment  — never commit real credentials
# ---------------------------------------------------------------------------
# Ignore all env files except the committed example.
.env
.env.*
!.env.example
*.pem
*.key

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------------------------------------------------------------
# Next.js build output
# ---------------------------------------------------------------------------
/.next/
/out/
/build
/dist

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
/coverage

# ---------------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# Caches / tooling
# ---------------------------------------------------------------------------
.turbo/
.eslintcache

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
